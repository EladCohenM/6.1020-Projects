{
  "name": "ps3",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "scripts": {
    "compile": "tsc",
    "examples": "tsc && node --require source-map-support/register dist/src/examples.js",
    "watch": "tsc --watch --preserveWatchOutput",
    "web": "tsc && node --require source-map-support/register dist/src/web-server.js",
    "start": "tsc && node --require source-map-support/register dist/src/main.js",
    "lint": "tsc && eslint",
    "test": "tsc || exit ; eslint ; mocha --require source-map-support/register dist/test",
    "coverage": "c8 npm test",
    "debug": "tsc && node --require source-map-support/register dist/src/debug.js"
  },
  "mocha": {
    "reporter": "spec",
    "exit": true
  },
  "c8": {
    "extension": [
      ".js"
    ],
    "exclude": [
      "coverage/"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "all": true
  },
  "dependencies": {
    "@jspm/core": "^2.1.0",
    "canvas": "^3.2.1",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "parserlib": "file:/./lib/parserlib-4.0.2.tgz"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.9",
    "c8": "^10.1.3",
    "eslint": "^9.39.2",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-jsdoc": "^62.4.1",
    "mocha": "^11.7.5",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
