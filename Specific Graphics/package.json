{
  "name": "ps1",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "^24.11.x"
  },
  "scripts": {
    "compile": "tsc",
    "start": "tsc && node --require source-map-support/register dist/src/main.js",
    "lint": "tsc && eslint",
    "test": "tsc || exit ; mocha --require source-map-support/register dist/test",
    "coverage": "c8 npm test"
  },
  "mocha": {
    "reporter": "spec",
    "exit": true
  },
  "c8": {
    "extension": [
      ".js"
    ],
    "exclude": [
      "coverage/"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "all": true
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.9",
    "c8": "^10.1.3",
    "eslint": "^9.39.2",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-jsdoc": "^62.4.1",
    "mocha": "^11.7.5",
    "open": "^11.0.0",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
